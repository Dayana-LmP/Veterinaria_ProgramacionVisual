<Window x:Class="ProyectoVeterinaria.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:customcontrols="clr-namespace:ProyectoVeterinaria.CustomControls"
        Title="Huella Soft" Height="500" Width="850"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="20" Background="White" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="60,0">
                <TextBlock Text="Huella Soft" FontSize="35" FontWeight="Bold" Foreground="#0644A7" Margin="0,0,0,30"/>

                <TextBlock Text="User name" Foreground="Gray" Margin="0,10,0,5"/>
                <TextBox Height="35" VerticalContentAlignment="Center" BorderBrush="#9FCEEC" BorderThickness="0,0,0,2"/>

                <TextBlock Text="Password" Foreground="Gray" Margin="0,20,0,5"/>
                <customcontrols:BindablePasswordBox Height="35"/>

                <Button Content="Login" Margin="0,40,0,0" Height="45" Background="#2375B1" Foreground="White" FontSize="16" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Border Grid.Column="1" Background="#2375B1">
                <StackPanel VerticalAlignment="Center" Margin="40">
                    <TextBlock Text="Cuidamos la salud y felicidad de tus mascotas con profesionalismo, cariño y dedicación." 
                               Foreground="White" FontSize="20" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,30"/>

                    <!--<Ellipse Width="120" Height="120" Fill="#65AEDB" Stroke="White" StrokeThickness="2"/> -->
                    <Ellipse Width="120" Height="120" HorizontalAlignment="Center">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/Images/vet.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <TextBlock Text="Veterinaria Huella Soft" Foreground="#9FCEEC" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="White" Margin="15" FontWeight="Bold" Click="btnCerrar_Click"/>
        </Grid>
    </Border>
</Window>