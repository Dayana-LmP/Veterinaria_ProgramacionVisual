<Window x:Class="ProyectoVeterinaria.Views.Consultas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoVeterinaria.Views"
        mc:Ignorable="d"
        Title="Consultas" Height="805" Width="800"
        Background="#F4F7F9"
        FontFamily="Segoe UI">
    <Grid>
        <!-- COLUMNAS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU IZQUIERDO -->
        <Border Background="#2375B1">

            <StackPanel>

                <!-- LOGO -->
                <TextBlock Text="Huella Soft"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="20,20,0,30"/>

                <!-- BOTONES -->
                <!--<Button Content="🏠  Home" Height="45" Background="Transparent" Foreground="White" BorderThickness="0"/> 
                <Button Content="📋  Consultas" Height="45" Background="Transparent" Foreground="White" BorderThickness="0"/>
                <Button Content="🐾  Mascotas" Height="45" Background="Transparent" Foreground="White" BorderThickness="0"/>
                <Button Content="👤  Dueños" Height="45" Background="Transparent" Foreground="White" BorderThickness="0"/>
                <Button Content="💉  Vacunas" Height="45" Background="Transparent" Foreground="White" BorderThickness="0"/>
                <Button Content="💊  Medicamentos" Height="45" Background="Transparent" Foreground="White" BorderThickness="0"/>
                <Button Content="👥  Empleados" Height="45" Background="Transparent" Foreground="White" BorderThickness="0"/>-->
                <Button Content="🏠  Home" Height="45" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0644A7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!--|Boton 2-->
                <Button Content="📋  Consultas" Height="45" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0644A7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!--Boton 3-->
                <Button Content="🐾  Mascotas" Height="45" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0644A7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!--Boton 4-->
                <Button Content="👤  Dueños" Height="45" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0644A7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!--Boton 5-->
                <Button Content="💉  Vacunas" Height="45" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0644A7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!--Boton 6-->
                <Button Content="💊  Medicamentos" Height="45" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0644A7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!--Boton 7-->
                <Button Content="👥  Empleados" Height="45" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0644A7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>


                <StackPanel Margin="10,150,10,0">
                    

                    <Button Content="↪ Salir" Height="45" Foreground="White" BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0644A7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>

            </StackPanel>

        </Border>


        <!-- CONTENIDO DERECHO -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Background="White">

                <Grid>

                    <TextBox Width="250"
                             Height="30"
                             Margin="20,0,0,0"
                             VerticalAlignment="Center"
                             Text="Buscar" TextChanged="TextBox_TextChanged"/>

                    
                    <Ellipse Width="40" Height="40" HorizontalAlignment="Right" Margin="0,0,20,0">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/Images/vet.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>


                </Grid>

            </Border>


            <!-- CONTENIDO -->
            <ScrollViewer Grid.Row="1">

                <StackPanel Margin="40">

                    <!-- TITULO -->
                    <TextBlock Text="Consulta"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>


                    <!-- FORM -->
                    <Border Background="White"
                            Padding="25"
                            Width="500"
                            CornerRadius="10"
                            BorderBrush="#DDD"
                            BorderThickness="1">

                        <StackPanel>

                            <TextBlock Text="Nombre de la mascota"/>
                            <TextBox Height="30" Margin="0,5,0,15"/>

                            <TextBlock Text="Nombre del dueño"/>
                            <TextBox Height="30" Margin="0,5,0,15"/>

                            <TextBlock Text="Servicio a solicitar"/>
                            <TextBox Height="30" Margin="0,5,0,15"/>

                            <TextBlock Text="¿Requiere alguna vacuna?" Margin="0,10,0,10"/>

                            <StackPanel Orientation="Horizontal">

                                <Button Content="SI"
                                        Width="60"
                                        Height="30"
                                        Background="#C6D9F1"
                                        Margin="0,0,10,0"/>

                                <Button Content="NO"
                                        Width="60"
                                        Height="30"
                                        Background="#F4CCCC"/>

                            </StackPanel>

                        </StackPanel>

                    </Border>


                    <!-- BOTON GUARDAR -->
                    <Button Content="GUARDAR"
                            Width="120"
                            Height="35"
                            Background="#4A86E8"
                            Foreground="White"
                            Margin="0,20,0,20"/>


                    <!-- TABLA -->
                    <DataGrid Height="200"
                              AutoGenerateColumns="False">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Mascota" Binding="{Binding Mascota}" Width="*"/>

                            <DataGridTextColumn Header="Veterinario" Binding="{Binding Veterinario}" Width="*"/>

                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </Grid>

</Window>
